{
  "name": "marketing-engine",
  "version": "0.4.0",
  "description": "Provider-agnostic AI marketing engine. CLI that drops into any host project. Pipeline: brief -> script -> creative -> caption -> compliance -> publish -> metrics -> ads. Switch LLM/image/video provider via env, never via skill rewrite.",
  "license": "Apache-2.0",
  "type": "module",
  "author": "Wesley Simplicio <wesleybob4@gmail.com>",
  "homepage": "https://github.com/wesleysimplicio/marketing-engine#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wesleysimplicio/marketing-engine.git"
  },
  "bugs": {
    "url": "https://github.com/wesleysimplicio/marketing-engine/issues"
  },
  "keywords": [
    "marketing",
    "ai",
    "content-pipeline",
    "llm",
    "claude",
    "openai",
    "deepseek",
    "playwright",
    "provider-agnostic",
    "cli",
    "automation",
    "social-media",
    "instagram",
    "tiktok",
    "linkedin",
    "ads"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "marketing-engine": "./bin/marketing-engine.mjs"
  },
  "files": [
    "bin",
    "lib",
    ".skills",
    ".specs",
    ".ralph",
    "playwright.config.ts",
    "tsconfig.json",
    ".env.example",
    "AGENTS.md",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "npm run test:node && npm run test:e2e",
    "test:node": "node --import tsx/esm --test \"tests/unit/**/*.test.*\" \"tests/integration/**/*.test.*\" \"tests/regression/**/*.test.*\" \"tests/benchmark/**/*.test.*\"",
    "test:unit": "node --import tsx/esm --test \"tests/unit/**/*.test.*\"",
    "test:integration": "node --import tsx/esm --test \"tests/integration/**/*.test.*\"",
    "test:regression": "node --import tsx/esm --test \"tests/regression/**/*.test.*\"",
    "test:benchmark": "node --import tsx/esm --test \"tests/benchmark/**/*.test.*\"",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "bench": "node --import tsx/esm scripts/bench.mjs",
    "conformance": "node --import tsx/esm lib/cli/conformance.ts",
    "bench:conformance": "node --import tsx/esm scripts/bench-conformance.mjs",
    "coverage": "c8 --reporter=text --reporter=html --reporter=json-summary --exclude \"tests/**\" --exclude \"e2e/**\" --exclude \"scripts/**\" --exclude \"lib/providers/__mocks__/**\" npm run test:node",
    "typecheck": "tsc --noEmit",
    "lint": "node scripts/lint-conventions.mjs",
    "check": "node scripts/check.mjs",
    "claims:audit": "node scripts/claims-audit.mjs",
    "budget": "node scripts/token-budget.mjs",
    "demo:asolaria": "node scripts/demo-asolaria-loop.mjs",
    "benchmark:reductions": "node scripts/reductions-benchmark.mjs",
    "router:check": "bash .ralph/provider-check.sh",
    "cli": "node bin/marketing-engine.mjs",
    "cli:init": "node bin/marketing-engine.mjs init",
    "cli:check": "node bin/marketing-engine.mjs check",
    "cli:generate": "node bin/marketing-engine.mjs generate",
    "cli:promote": "node bin/marketing-engine.mjs promote",
    "smoke": "node bin/marketing-engine.mjs help && node bin/marketing-engine.mjs generate",
    "format:policy": "node scripts/check-internal-formats.mjs",
    "format:policy:strict": "node scripts/check-internal-formats.mjs --strict"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.0.0",
    "c8": "^11.0.0",
    "dotenv": "^16.4.5",
    "fast-check": "^4.9.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "tsx": "^4.22.1"
  }
}
