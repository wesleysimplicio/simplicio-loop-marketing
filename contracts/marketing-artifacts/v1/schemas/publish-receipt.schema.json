{
  "$id": "marketing-publish-receipt/v1",
  "type": "object",
  "required": ["schema", "ts", "piece_id", "verdict", "claims_tag", "attempts", "stages"],
  "properties": {
    "schema": { "const": "marketing-publish-receipt/v1" },
    "ts": { "type": "string" },
    "piece_id": { "type": "string" },
    "client": { "type": "string" },
    "provider": { "type": "string" },
    "dry_run": { "type": "boolean" },
    "verdict": { "enum": ["published", "blocked", "failed"] },
    "claims_tag": { "enum": ["MEASURED", "CANON", "UNVERIFIED"] },
    "attempts": { "type": "integer" },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["stage", "ok"],
        "properties": {
          "stage": { "type": "string" },
          "ok": { "type": "boolean" },
          "detail": { "type": "string" }
        }
      }
    },
    "failure_class": { "type": "string" },
    "post_ref": { "type": "string" }
  }
}
