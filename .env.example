ACTIVE_CLIENT=saas-consultoria-imagem
LLM_DEFAULT=claude
LLM_FALLBACK=codex
LLM_CHEAP=deepseek

# LLM providers
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
# Optional DeepSeek pricing overrides (USD per 1k tokens)
# DEEPSEEK_CHAT_INPUT_USD_PER_1K=0.00014
# DEEPSEEK_CHAT_OUTPUT_USD_PER_1K=0.00028
# DEEPSEEK_REASONER_INPUT_USD_PER_1K=0.00055
# DEEPSEEK_REASONER_OUTPUT_USD_PER_1K=0.0022
ANTHROPIC_API_KEY=
# Local fallback — leave OLLAMA_HOST blank to skip
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Image / video providers
HIGGSFIELD_MCP_ACTIVE=true
TOPVIEW_API_KEY=
WAVESPEED_API_KEY=
# HyperFrames is a local HTML→MP4 renderer; no API key needed.
# Set HYPERFRAMES_ACTIVE=true once `npx hyperframes doctor` passes locally
# (Node >= 22, FFmpeg on PATH). See https://github.com/wesleysimplicio/hyperframes
HYPERFRAMES_ACTIVE=false

# Publish + ads
ADAPTLYPOST_API_KEY=
META_ADS_MCP_ACTIVE=true

# Analytics (production fetchers; DRY_RUN keeps deterministic synthetic data)
META_ACCESS_TOKEN=
META_PAGE_ID=
TIKTOK_ACCESS_TOKEN=
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=

# Calendar
NOTION_TOKEN=
NOTION_CALENDAR_DB_ID=

# Optional observability webhook (Slack/Discord/generic POST)
ALERT_WEBHOOK_URL=

# Compliance: when false, enables an extra LLM secondary pass on the report
COMPLIANCE_LLM_SECONDARY=false

# Always start in DRY_RUN. Flip to false only after a human review of one piece.
DRY_RUN=true

# Optional local/operator overrides (all safe to leave blank)
MARKETING_ENGINE_HOST_ROOT=
MARKETING_ENGINE_DOCTOR_MISSING=
PLAYWRIGHT_BROWSERS_PATH=
LOCALAPPDATA=
SIMPLICIO_DISABLE_RUN_LOG=0
PROVIDERS_MATRIX_PATH=
MAX_ITER=
MARKETING_ENGINE_PIECES_DIR=
MARKETING_ENGINE_OUTPUTS_DIR=
MARKETING_LOOP_PY_WORKERS=0
SIMPLICIO_LOOP_ROOT=
MARKETING_ENGINE_SCHEDULE_PLATFORM=
SIMPLICIO_EVENTS_MAX_BYTES=
MARKETING_ENGINE_SCHEDULE_CRONTAB_FILE=
MARKETING_ENGINE_SCHEDULE_LAUNCH_AGENTS_DIR=
MARKETING_ENGINE_SCHEDULE_LAUNCHCTL_LOG=
MARKETING_ENGINE_SCHEDULE_UID=
MARKETING_WATCHER_MAX_CYCLES=
# Release-train observation metadata (normally injected by Loop core/CI)
SIMPLICIO_LOOP_LATEST_VERSION=
SIMPLICIO_LOOP_COMPATIBLE=
SIMPLICIO_LOOP_BLOCKED_REASON=
SIMPLICIO_ECOSYSTEM_RELEASE_ID=
